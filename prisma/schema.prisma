generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Quiz {
  id           String         @id
  title        String
  description  String?
  createdAt    DateTime       @default(now())
  userId       String         @default("default_user")
  User         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  QuizQuestion QuizQuestion[]
}

model QuizQuestion {
  id        String   @id
  quizId    String
  question  String
  answer    String
  options   String[]
  createdAt DateTime @default(now())
  Quiz      Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
}

model Sentence {
  id        String   @id
  dutch     String
  arabic    String
  wordId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime
  userId    String   @default("default_user")
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  Word      Word?    @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@unique([dutch, userId])
}

model User {
  id        String     @id
  username  String     @unique
  password  String
  createdAt DateTime   @default(now())
  Quiz      Quiz[]
  Sentence  Sentence[]
  Word      Word[]
}

model Word {
  id            String     @id
  dutch         String     @unique
  arabicMeaning String
  otherMeaning  String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime
  userId        String     @default("default_user")
  Sentence      Sentence[]
  User          User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([dutch, userId])
}
